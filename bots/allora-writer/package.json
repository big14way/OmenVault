{
  "name": "@omenvault/allora-writer",
  "version": "0.1.0",
  "private": true,
  "description": "Polls a forecast source (Allora REST when configured; CoinGecko momentum in demo mode) and writes P(YES) to AlloraConsumer on Mantle Sepolia.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@omenvault/shared": "workspace:*",
    "ethers": "^6.13.4",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
