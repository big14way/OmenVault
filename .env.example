# ===========================================================================
# OmenVault — environment template
# Copy to .env at the repo root. Bots and the web app both read from this.
# ===========================================================================

# --- Chain (Sepolia, testnet) ---
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
CHAIN_ID=5003

# --- Chain (Mantle mainnet, chain id 5000) ---
# Used only by script/DeployMainnet.s.sol. No PRIVATE_KEY here on purpose:
# the mainnet flow signs from the Foundry encrypted keystore via --account.
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz
MANTLE_MAINNET_EXPLORER_API_KEY=
USDT0_ADDRESS_MAINNET=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
DEPLOYER_ADDRESS=

# Deployer / bot signing keys (DO NOT commit values)
PRIVATE_KEY=
TRADER_PRIVATE_KEY=
ORACLE_A_PRIVATE_KEY=
ORACLE_B_PRIVATE_KEY=
ORACLE_C_PRIVATE_KEY=

# --- Deployed addresses (filled in by Deploy.s.sol) ---
AGENT_REGISTRY_ADDRESS=
MARKET_FACTORY_ADDRESS=
ORACLE_SWARM_ADDRESS=
ALLORA_CONSUMER_ADDRESS=
DECISION_LOG_ADDRESS=

# Mantle Sepolia primitive token addresses (placeholder, fill in for real deployment)
USDT0_ADDRESS=
SUSDE_ADDRESS=
USDY_ADDRESS=

# --- Partner APIs ---

# Allora — writer bot (bots/allora-writer)
#   ALLORA_API_BASE unset → demo mode (CoinGecko 24h momentum → P(YES))
#   ALLORA_API_BASE set   → real path, GET {base}/allora/{topic}/latest
ALLORA_API_BASE=
ALLORA_API_KEY=
ALLORA_TOPICS=14,1,8
ALLORA_POLL_INTERVAL_SEC=60
# Trader-side read freshness:
ALLORA_STALENESS_SEC=900

# Nansen — watcher bot (bots/nansen-watcher)
#   NANSEN_API_KEY unset → demo mode (deterministic moving signal per address)
#   NANSEN_API_KEY set   → real path against NANSEN_API_BASE
NANSEN_API_KEY=
NANSEN_API_BASE=https://api.nansen.ai
NANSEN_WATCHER_PORT=7755
NANSEN_POLL_INTERVAL_SEC=60
# Comma-separated tokens to pre-warm; defaults to NEXT_PUBLIC_USDT0_ADDRESS
NANSEN_WATCH_TOKENS=

# Pyth (Hermes — pull-based, no key needed). Used by Oracle C.
PYTH_HERMES_URL=https://hermes.pyth.network

# --- AI ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- IPFS pinning (for reasoning blobs) ---
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- Web app ---
NEXT_PUBLIC_CHAIN_ID=5003
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.mantle.xyz
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_ORACLE_SWARM_ADDRESS=
NEXT_PUBLIC_DECISION_LOG_ADDRESS=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
