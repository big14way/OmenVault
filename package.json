{
  "name": "omenvault",
  "version": "0.1.0",
  "private": true,
  "description": "RWA-collateralized prediction markets on Mantle with ERC-8004 AI agents",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "bots/*"
  ],
  "scripts": {
    "contracts:build": "pnpm --filter @omenvault/contracts build",
    "contracts:test": "pnpm --filter @omenvault/contracts test",
    "contracts:deploy": "pnpm --filter @omenvault/contracts deploy",
    "web:dev": "pnpm --filter @omenvault/web dev",
    "web:build": "pnpm --filter @omenvault/web build",
    "bots:trader": "pnpm --filter @omenvault/trader start",
    "bots:oracle": "pnpm --filter @omenvault/oracle-swarm start",
    "bots:nansen": "pnpm --filter @omenvault/nansen-watcher start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
